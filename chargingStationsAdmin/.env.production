# Конфигурация production-сборки (npm run build). Секретов нет — файл в git.
# Панель и API обслуживает один и тот же nginx, поэтому запросы идут по
# ОТНОСИТЕЛЬНЫМ корневым путям (/user, /contractor-admin, /websocket, ...) на тот же origin.

# Реальный бэкенд (не мок).
VITE_DATA_SOURCE=api

# Пусто → относительные пути (same-origin через nginx). НЕ задавать абсолютный URL:
# админка и API на одном хосте, иначе словите CORS.
VITE_API_BASE=
