# Источник данных: mock (по умолчанию, демо без бэкенда) | api (реальный шлюз)
VITE_DATA_SOURCE=mock

# База для запросов клиента. Пусто → относительные пути (dev: прокси Vite, prod: nginx).
# Можно указать абсолютный URL шлюза, если фронт и API на разных origin.
VITE_API_BASE=

# Цель dev-прокси Vite (куда проксируются /user, /contractor-admin, /station-controll, ...).
VITE_GATEWAY_URL=http://localhost:8010

# Keycloak (для будущего прямого OIDC-флоу; сейчас вход идёт через user-service).
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=charging-stations
VITE_KEYCLOAK_CLIENT_ID=user-service
