# ==========================================================================
# Конфигурация деплоя (docker-compose.prod.yaml).
# Скопируй в .env и подставь свои значения:  cp .env.example .env
# Файл .env в .gitignore — секреты в репозиторий не попадают.
# ==========================================================================

# Публичный адрес сервера (IP или домен) — используется для:
#  - Keycloak KC_HOSTNAME и issuer токенов
#  - ссылок в письмах (user/notification)
#  - callback-URL для O!Dengi
SERVER_HOST=localhost

# -------------------- Пароли баз данных (ОБЯЗАТЕЛЬНО сменить) --------------------
STATION_DB_PASSWORD=changeme
USER_DB_PASSWORD=changeme
PAYMENT_DB_PASSWORD=changeme
BOOKING_DB_PASSWORD=changeme
CONTRACTOR_DB_PASSWORD=changeme
KEYCLOAK_DB_PASSWORD=changeme
STEVE_DB_PASSWORD=changeme

# -------------------- Keycloak --------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
# Секрет клиента user-service в realm charging-stations.
# Должен совпадать со значением в импортируемом realm (keycloak-realm-config / setup-keycloak.py).
KEYCLOAK_CLIENT_SECRET=lk6oom9CCmAsItuL9P5uSKI7vd0HuIBa

# -------------------- Почта (Gmail SMTP) — user/notification --------------------
